---
import BaseLayout from '../layouts/BaseLayout.astro';

const name = 'Demo Runway';
const tagline = 'The starting line every demo inherits.';
const title = 'Demo Runway — the starting line every demo inherits';
const description =
  'A working, public web page you can build your demo on top of. The live URL and deploy-on-push land next.';
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="clay-surface" aria-labelledby="title">
      <p class="eyebrow">Ready when you are</p>
      <h1 id="title">{name}</h1>
      <p class="tagline">{tagline}</p>
      <p class="lede">
        This is the working starting point. It's live, it's static, and it costs
        nothing to leave running. Point your coding agent at it and build the
        demo you came to make — the public URL and deploy-on-push arrive next.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  /* Page-specific styling only — global tokens/primitives live in
     src/styles/*. Every value resolves from tokens.css (var(--…)); no literals
     here, which is the visible proof the page uses tokens, not browser
     defaults. Retheme happens in tokens.css, never in this file. */
  /* Centering, gutter, and viewport-fill now live in the shared .page shell
     (BaseLayout / base.css). The page contributes only its content and the
     card's measure. */
  .clay-surface {
    max-width: var(--measure);
    width: 100%;
    margin-inline: auto; /* center the card within the full-width page shell */
    padding: clamp(var(--space-lg), 5vw, var(--space-xl));
  }

  .eyebrow {
    margin: 0 0 var(--space-xs);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  h1 {
    margin: 0 0 var(--space-2xs);
    font-weight: 600;
    font-size: var(--text-3xl);
  }

  .tagline {
    margin: 0 0 var(--space-md);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-accent);
  }

  .lede {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text-soft);
    max-width: 32rem;
  }
</style>
