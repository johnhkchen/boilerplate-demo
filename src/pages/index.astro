---
import BaseLayout from '../layouts/BaseLayout.astro';

// ─── Template slots ─────────────────────────────────────────────
// Every generated demo names these two things from its idea. The
// page copy leans on them, so renaming here reshapes the surface.
const DEMO_NAME = 'Demo Runway';
const PRIMARY_ACTION_LABEL = 'Ask for a fresh note';
// ────────────────────────────────────────────────────────────────

const tagline = 'The starting line every demo inherits.';
const title = `${DEMO_NAME} — the starting line every demo inherits`;
const description =
  'A live demo page: watch the server answer with a freshly signed note, and leave the team a note of your own.';
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="clay-surface" aria-labelledby="title">
      <p class="eyebrow">Start here</p>
      <h1 id="title">{DEMO_NAME}</h1>
      <p class="tagline">{tagline}</p>
      <p class="lede">
        You've landed on a working demo page — live right now, and yours to
        try. Two things to do here: watch the card below get a freshly signed
        answer from the server, and further down, leave the team a note of
        your own.
      </p>
    </section>

    <!-- The live boundary made page-visible. The page itself is a plain file that
         loads instantly; the card below is filled a moment later by asking the
         server (/api/receipt) for a freshly signed note. The signing key stays on
         the server — it is never in this page's source or scripts. -->
    <section class="clay-surface receipt" aria-labelledby="receipt-heading" aria-live="polite">
      <p class="eyebrow">Watch the server answer</p>
      <h2 id="receipt-heading">A signed note, made just now</h2>
      <p class="lede">
        The page around this card is just a file — it loads instantly. This
        card is the one live part: it asks the server for a freshly signed
        note, made with a key your browser never sees. Here's what came back —
        and you can ask for another anytime.
      </p>
      <div class="clay-well receipt-panel">
        <p id="receipt-status" class="receipt-status">Asking the server…</p>
        <dl id="receipt-body" class="receipt-body" hidden>
          <div class="receipt-row">
            <dt>Made at</dt>
            <dd id="receipt-issued">—</dd>
          </div>
          <div class="receipt-row">
            <dt>One-time tag</dt>
            <dd id="receipt-nonce" class="receipt-code">—</dd>
          </div>
          <div class="receipt-row">
            <dt>The server's signature</dt>
            <dd id="receipt-signature" class="receipt-code">—</dd>
          </div>
        </dl>
      </div>
      <button type="button" id="primary-action" class="clay-button primary-action">
        {PRIMARY_ACTION_LABEL}
      </button>
    </section>

    <section class="clay-surface" aria-labelledby="note-heading">
      <p class="eyebrow">Leave a note</p>
      <h2 id="note-heading">Pass the team a thought</h2>
      <p class="lede">
        Got a link, an example, or a bit of feedback for the people building
        this? There's a page for that — no account, no sign-in.
      </p>
      <a id="backstage-link" class="backstage-link" href="/backstage">
        Leave a note for the team
      </a>
    </section>
  </main>
</BaseLayout>

<script>
  // Runs in the browser: the page is static, so it fetches the live boundary and
  // fills the card — once on load, and again whenever the primary action asks.
  // Only a relative request + DOM writes live here — no secret.
  const statusEl = document.getElementById('receipt-status');
  const bodyEl = document.getElementById('receipt-body');
  const set = (id: string, value: string) => {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  };

  interface ReceiptPayload {
    issuedAt: string;
    nonce: string;
    signature: string;
  }

  const isReceiptPayload = (value: unknown): value is ReceiptPayload => {
    if (typeof value !== 'object' || value === null) return false;
    const candidate = value as Record<string, unknown>;
    return (
      typeof candidate.issuedAt === 'string' &&
      typeof candidate.nonce === 'string' &&
      typeof candidate.signature === 'string'
    );
  };

  async function loadReceipt(): Promise<void> {
    if (statusEl) {
      statusEl.textContent = 'Asking the server…';
      statusEl.hidden = false;
    }
    if (bodyEl) bodyEl.hidden = true;
    try {
      const res = await fetch('/api/receipt', { headers: { accept: 'application/json' } });
      if (!res.ok) throw new Error(`server answered ${res.status}`);
      const receipt: unknown = await res.json();
      if (!isReceiptPayload(receipt)) throw new Error('unexpected receipt response');
      set('receipt-issued', new Date(receipt.issuedAt).toLocaleString());
      set('receipt-nonce', receipt.nonce);
      set('receipt-signature', receipt.signature);
      if (statusEl) statusEl.hidden = true;
      if (bodyEl) bodyEl.hidden = false;
    } catch {
      if (statusEl) {
        statusEl.textContent = "The server didn't answer just now — try a refresh.";
      }
    }
  }

  // Wire the primary action before the first load so it works even while the
  // initial fetch is still in flight. Disabled during a round trip so a
  // double-tap can't race two requests into the aria-live card.
  const primaryAction = document.getElementById('primary-action') as HTMLButtonElement | null;
  primaryAction?.addEventListener('click', async () => {
    primaryAction.disabled = true;
    try {
      await loadReceipt();
    } finally {
      primaryAction.disabled = false;
    }
  });

  await loadReceipt();
</script>

<style>
  /* Page-specific styling only — global tokens/primitives live in
     src/styles/*. Every value resolves from tokens.css (var(--…)); no literals
     here, which is the visible proof the page uses tokens, not browser
     defaults. Retheme happens in tokens.css, never in this file. */
  /* Centering, gutter, and viewport-fill now live in the shared .page shell
     (BaseLayout / base.css). The page contributes only its content and the
     card's measure. */
  /* Two stacked cards now: the intro and the live boundary. main owns the
     rhythm between them; each card still caps to the reading measure. */
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    width: 100%;
  }

  .clay-surface {
    max-width: var(--measure);
    width: 100%;
    margin-inline: auto; /* center the card within the full-width page shell */
    padding: clamp(var(--space-lg), 5vw, var(--space-xl));
  }

  h2 {
    margin: 0 0 var(--space-2xs);
    font-weight: 600;
    font-size: var(--text-2xl);
  }

  .eyebrow {
    margin: 0 0 var(--space-xs);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  h1 {
    margin: 0 0 var(--space-2xs);
    font-weight: 600;
    font-size: var(--text-3xl);
  }

  .tagline {
    margin: 0 0 var(--space-md);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-accent);
  }

  .lede {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text-soft);
    max-width: 32rem;
  }

  /* --- Live boundary card --------------------------------------------------
     The inset well is the pressed-in counterpart of the raised card (clay
     vocabulary). It holds the server's answer once it arrives. */
  .receipt-panel {
    margin-top: var(--space-md);
    padding: clamp(var(--space-md), 4vw, var(--space-lg));
  }

  .receipt-status {
    margin: 0;
    color: var(--color-text-soft);
    font-size: var(--text-base);
  }

  .receipt-body {
    margin: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .receipt-row {
    display: grid;
    gap: var(--space-3xs);
  }

  .receipt-body dt {
    margin: 0;
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  .receipt-body dd {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text);
  }

  /* Machine values (the one-time tag and the signature) are long hex strings.
     Let them wrap anywhere so they never push past a narrow phone viewport, and
     even out the digits for legibility. No mono font token exists yet, so this
     stays on the body font rather than introducing a literal font-family. */
  .receipt-code {
    overflow-wrap: anywhere;
    font-variant-numeric: tabular-nums;
    color: var(--color-text-soft);
  }

  /* The page's one primary action. The clay-button primitive (base.css) owns
     the look; the page adds only the rhythm between the well and the button. */
  .primary-action {
    margin-top: var(--space-md);
  }

  /* The front-door path to backstage: a plain accent link, deliberately NOT a
     clay-button — the page has exactly one of those. inline-flex + the shared
     control height keep the tap target at 44px on a phone (P3) without making
     the link look pressable like the primary action. */
  .backstage-link {
    display: inline-flex;
    align-items: center;
    min-height: var(--control-height);
    margin-top: var(--space-sm);
    color: var(--color-accent);
    font-weight: 700;
    font-size: var(--text-base);
    text-decoration: underline;
    text-underline-offset: var(--space-3xs);
  }
</style>
