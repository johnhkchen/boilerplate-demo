{
  "name": "demo-runway",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "test": "node --experimental-strip-types --test test/operation-runner.test.mjs test/ops-check.test.mjs test/fault.test.mjs test/leak-check.test.mjs test/integration-check.test.mjs test/passcode.test.mjs test/backstage-store.test.mjs test/backstage-route.test.mjs",
    "ops:check": "node --experimental-strip-types scripts/ops-check.ts",
    "leak:check": "node --experimental-strip-types scripts/leak-check.ts",
    "integration:check": "node --experimental-strip-types scripts/integration-check.ts",
    "test:flow": "playwright test --project=healthy",
    "test:flow:stalled": "playwright test --project=stalled",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "astro build && wrangler deploy",
    "deploy:dry": "astro build && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.19.7",
    "astro": "^5.13.0",
    "wrangler": "^4"
  }
}
