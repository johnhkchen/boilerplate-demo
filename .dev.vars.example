# .dev.vars.example — the checked-in environment template (NO real secrets).
#
# One-command local dev: copy this file to `.dev.vars` (gitignored) and set a real
# value, then `npm run dev`. The Cloudflare adapter's platformProxy loads `.dev.vars`
# and exposes these at `Astro.locals.runtime.env` for the /api/receipt boundary.
#
# In production the same variable is a Worker secret:
#   npx wrangler secret put DEMO_SIGNING_KEY
#
# Server-only signing key for the /api/receipt boundary. Never commit the real key.
DEMO_SIGNING_KEY="replace-with-a-long-random-string"

# Shared low-stakes passcode for the stakeholder backstage. Nontechnical collaborators
# present it in the `x-demo-passcode` request header to submit references/feedback, and
# a coding agent presents it to retrieve entries. It is a lightweight shared knock, NOT
# a server secret — but it is still read only server-side and never shipped in a browser
# bundle. A blank value makes the gate fail closed (500). In production it is a Worker
# secret: `npx wrangler secret put DEMO_PASSCODE`.
DEMO_PASSCODE="replace-with-a-shared-passcode"

# Optional: put the boundary into a deliberate fault to watch `npm run ops:check`
# catch it. Leave unset for a healthy demo. 'broken' serves a signed note whose
# signature the check rejects; 'stalled' makes the boundary never answer; 'leak'
# deliberately puts this key in the response so `npm run leak:check` must fail and
# name the response body. Never enable leak outside deliberate verification.
# (Anything else is treated as unset, so the server never breaks by accident.)
# DEMO_FAULT="broken"

# Run the complete operation + browser + leak gate without editing this file:
#   npm run integration:check
#   DEMO_FAULT=broken npm run integration:check   # also: stalled, leak
# The combined command owns a disposable key/config and local server. See
# docs/knowledge/integration-check.md. Never use leak mode on a shared deployment.
