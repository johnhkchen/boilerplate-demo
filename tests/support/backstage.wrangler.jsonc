{
  // Isolated Wrangler config for the backstage phone-flow Playwright dev server.
  //
  // Why this file exists: it lives OUTSIDE the repo root, so Wrangler infers this
  // directory as the project root and does NOT load the developer's repo-root
  // `.dev.vars` (which may pin a machine-specific DEMO_PASSCODE / DEMO_SIGNING_KEY and
  // would otherwise override the test's values). The dev server is pointed here via
  // DEMO_WRANGLER_CONFIG_PATH (read by astro.config.mjs into platformProxy). With
  // `.dev.vars` out of the picture, DEMO_PASSCODE / DEMO_SIGNING_KEY come deterministically
  // from the Playwright webServer's process env (CLOUDFLARE_INCLUDE_PROCESS_ENV).
  //
  // The BACKSTAGE_DB binding is declared here because this config REPLACES wrangler.jsonc
  // for the emulated runtime. Playwright applies migrations with this same config before
  // starting Astro, ensuring a clean CI runner migrates the exact database it serves.
  // Not a deploy config.
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "demo-runway-backstage-flow",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "vars": { "DEMO_FAULT": "off" },
  "secrets": {
    "required": ["DEMO_SIGNING_KEY", "DEMO_PASSCODE"]
  },
  "d1_databases": [
    {
      "binding": "BACKSTAGE_DB",
      "migrations_dir": "../../migrations"
    }
  ]
}
