# build output — never committed; keeps deploy-ticket diffs clean
dist/

# dependencies
node_modules/

# astro generated types / content cache
.astro/

# wrangler local state / cache (deploy metadata, build artifacts)
.wrangler/

# promote/rollback records — machine-local cache; the durable ledger is the
# Cloudflare deployment history (version tags + deployment messages)
.promote/

# Playwright reports, traces, screenshots, and videos
test-results/
playwright-report/

# machine-local orchestration/browser workspace state
.lisa-layout.kdl
docs/.obsidian/

# generated by `wrangler check startup`
worker-startup.cpuprofile

# local secrets for the server-side boundary — real key lives here, never commit.
# The committed template is .dev.vars.example.
.dev.vars

# macOS
.DS_Store
